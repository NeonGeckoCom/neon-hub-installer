# Neon Hub — Windows .env
#
# Copy to .env (no extension) and edit values for your machine.
# Both PowerShell and cmd will pick up .env automatically when running
# `docker compose` from this directory.

# Absolute path to where the Hub keeps its data. Forward slashes only —
# Docker Desktop on WSL2 does NOT accept Windows backslash paths in bind
# mounts. %USERPROFILE% is shared with Docker by default.
#
# Example: C:/Users/Mike/neon-hub
NEON_HOME=C:/Users/YOUR_USERNAME/neon-hub

# Hostname used in the TLS cert SAN, in nginx server_name, and as the
# container hostname for RabbitMQ. Must match what you put in
# C:\Windows\System32\drivers\etc\hosts.
NEON_HOSTNAME=neon-hub-win.local

# Hub Linux-side username. Used for container hostnames and a few paths.
# Just leave this as `neon` unless you have a reason to change it.
NEON_USER=neon

# Standard XDG path inside the containers — leave as-is.
XDG_CONFIG_HOME=/xdg/config

# Hub timezone. Used by container clocks (Windows clock/timezone is not
# bind-mounted in).
TZ=America/Chicago

# Image tags. `dev` follows the alpha branch on each upstream repo.
# Pin to a specific alpha (e.g. 0.1.1a22) for reproducibility.
NEON_IMAGE_TAG=dev
MQ_IMAGE_TAG=dev
HTTP_IMAGE_TAG=dev
