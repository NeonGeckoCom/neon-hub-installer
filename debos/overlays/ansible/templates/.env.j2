NEON_USER=neon
NEON_CONFIG_FOLDER={{ neon_home }}/xdg/config
NEON_CONFIG_PHAL_FOLDER={{ neon_home }}/xdg/config
NEON_SHARE_FOLDER={{ neon_home }}/xdg/share
NEON_LOCAL_FOLDER={{ neon_home }}/xdg/local

MQ_IMAGE_TAG=dev
HTTP_IMAGE_TAG=dev
NEON_IMAGE_TAG=dev

XDG_CONFIG_HOME=/xdg/config
DIANA_XDG_PATH={{ neon_home }}/xdg
TZ={{ timezone }}
PULL_POLICY=Always
HOSTNAME={{ common_name }}

NEON_SKILLS_DIR=/xdg/config/neon/skills/
NEON_XDG_PATH={{ neon_home }}/xdg
{% if ansible_os_family == 'Darwin' %}
XDG_RUNTIME_DIR=/tmp
PULSE_SERVER=host.docker.internal
DISPLAY=
{% else %}
XDG_RUNTIME_DIR=/run/user/1000
PULSE_SERVER=unix:${XDG_RUNTIME_DIR}/pulse/native
PULSE_COOKIE=/xdg/config/pulse/cookie
DISPLAY=:0
{% endif %}
