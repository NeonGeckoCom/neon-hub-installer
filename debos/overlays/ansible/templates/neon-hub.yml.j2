x-podman: &podman
  userns_mode: keep-id
  security_opt:
    - "label=disable"
x-logging: &default-logging
  driver: json-file
  options:
    mode: non-blocking
    max-buffer-size: 4m
    max-size: "5m"
    max-file: "1"
x-default-env-vars: &default-env-vars
  XDG_CONFIG_HOME: $XDG_CONFIG_HOME
  TZ: $TZ

networks:
  neon-core:
volumes:
  xdg:
{% if ansible_os_family != 'Darwin' %}
    driver_opts:
      type: xdg
      o: bind
      device: ${NEON_XDG_PATH}
{% else %}
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ${NEON_XDG_PATH}
{% endif %}
  models:
    name: models
    driver: local
  vosk:
    name: vosk
    driver: local
  listener_records:
    name: listener_records
    driver: local
  tts_cache:
    name: tts_cache
    driver: local
  nltk:
    name: nltk
    driver: local
  local_state:
    name: local_state
    driver: local
  neon_gui_files:
    name: neon_gui_files
    driver: local
{% if ansible_os_family != 'Darwin' %}
  sdm-data:
    name: sdm-data
    driver: local
{% endif %}

services:
  # Core
  messagebus:
    <<: *podman
    logging: *default-logging
    restart: unless-stopped
    image: ghcr.io/neongeckocom/neon_messagebus:${NEON_IMAGE_TAG}
    container_name: neon-messagebus
    depends_on:
      - rabbitmq
    networks:
      neon-core:
        aliases:
          - neon-messagebus
    volumes:
      - ${NEON_CONFIG_FOLDER}:/xdg/config
      - ${NEON_LOCAL_FOLDER}:/xdg/local
{% if ansible_os_family != 'Darwin' %}
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
{% endif %}
    environment:
      <<: *default-env-vars
  speech:
    <<: *podman
    logging: *default-logging
    restart: unless-stopped
    depends_on:
      - messagebus
    image: ghcr.io/neongeckocom/neon_speech-default_model:${NEON_IMAGE_TAG}
    container_name: neon-speech
    networks:
      neon-core:
    volumes:
      - xdg:/home/neon:rw
{% if ansible_os_family != 'Darwin' %}
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
      - /home/${NEON_USER}/.config/pulse/cookie:/xdg/config/pulse/cookie:ro
{% endif %}
      - ${NEON_CONFIG_FOLDER}:/xdg/config:ro
      - listener_records:/xdg/local/share/neon/listener
      - ${NEON_LOCAL_FOLDER}:/xdg/local
      - models:/xdg/local/share/precise-lite
      - vosk:/xdg/local/share/vosk
    environment:
      <<: *default-env-vars
{% if ansible_os_family != 'Darwin' %}
    devices:
      - /dev/snd
{% endif %}
  audio:
    <<: *podman
    logging: *default-logging
    restart: unless-stopped
    depends_on:
      - messagebus
    image: ghcr.io/neongeckocom/neon_audio:${NEON_IMAGE_TAG}
    container_name: neon-audio
    networks:
      neon-core:
    volumes:
{% if ansible_os_family != 'Darwin' %}
      - ${XDG_RUNTIME_DIR}/bus:${XDG_RUNTIME_DIR}/bus:ro
      - /home/${NEON_USER}/.config/pulse/cookie:/xdg/config/pulse/cookie:ro
{% endif %}
      - ${NEON_CONFIG_FOLDER}:/xdg/config
      - ${NEON_LOCAL_FOLDER}:/xdg/local
      - tts_cache:/xdg/cache/neon
{% if ansible_os_family != 'Darwin' %}
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
{% endif %}
    environment:
      <<: *default-env-vars
{% if ansible_os_family != 'Darwin' %}
      DBUS_SESSION_BUS_ADDRESS: unix:path=${XDG_RUNTIME_DIR}/bus
{% endif %}
      LOG_LEVEL: INFO
{% if ansible_os_family != 'Darwin' %}
    devices:
      - /dev/snd
{% endif %}
  enclosure:
    <<: *podman
    logging: *default-logging
    restart: unless-stopped
    depends_on:
      - messagebus
    image: ghcr.io/neongeckocom/neon_enclosure:${NEON_IMAGE_TAG}
    container_name: neon-enclosure
    networks:
      neon-core:
    volumes:
{% if ansible_os_family != 'Darwin' %}
      - ${XDG_RUNTIME_DIR}/pulse/cookie:${XDG_RUNTIME_DIR}/pulse/cookie:ro
      - ${XDG_RUNTIME_DIR}/bus:${XDG_RUNTIME_DIR}/bus:ro
      - /tmp/.X11-unix:/tmp/.X11-unix:ro
{% endif %}
      - ${NEON_CONFIG_FOLDER}:/xdg/config
      - ${NEON_LOCAL_FOLDER}:/xdg/local
{% if ansible_os_family != 'Darwin' %}
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
{% endif %}
    environment:
      <<: *default-env-vars
{% if ansible_os_family != 'Darwin' %}
      DISPLAY: ${DISPLAY}
      DBUS_SESSION_BUS_ADDRESS: unix:path=${XDG_RUNTIME_DIR}/bus
{% endif %}
{% if ansible_os_family != 'Darwin' %}
    devices:
      - /dev/snd
{% endif %}
  skills:
    <<: *podman
    logging: *default-logging
    restart: unless-stopped
    depends_on:
      - messagebus
    image: ghcr.io/neongeckocom/neon_skills-default_skills:${NEON_IMAGE_TAG}
    container_name: neon-skills
    networks:
      neon-core:
    volumes:
{% if ansible_os_family != 'Darwin' %}
      - /home/${NEON_USER}/.config/pulse/cookie:/xdg/config/pulse/cookie:ro
{% endif %}
      - ${NEON_CONFIG_FOLDER}:/xdg/config
      - ${NEON_LOCAL_FOLDER}:/xdg/local
      - nltk:/home/${NEON_USER}/nltk_data
      - ${NEON_SHARE_FOLDER}:/xdg/local/share/neon
{% if ansible_os_family != 'Darwin' %}
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
{% endif %}
{% if ansible_os_family != 'Darwin' %}
    devices:
      - /dev/snd
{% endif %}
    environment:
      <<: *default-env-vars
  # Hub
  rabbitmq:
    <<: *podman
    container_name: neon-rabbitmq
    image: rabbitmq:3-management
    ports:
      - 5672:5672
      - 15672:15672
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
        aliases:
          - neon-rabbitmq
    volumes:
      - {{ neon_home }}/xdg/config/rabbitmq:/etc/rabbitmq
    environment:
      - RABBITMQ_ENABLED_PLUGINS=rabbitmq_management
  # MQ Services
  api_proxy:
    <<: *podman
    container_name: neon-api-proxy
    image: ghcr.io/neongeckocom/neon_api_proxy:${MQ_IMAGE_TAG}
    depends_on:
      - rabbitmq
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
    volumes:
      - xdg:/xdg:rw
    environment:
      <<: *default-env-vars
  # HTTP Services
{% if ansible_os_family != 'Darwin' %}
  docker_manager:
    <<: *podman
    container_name: neon-docker-manager
    image: ghcr.io/oscillatelabsllc/simple-docker-manager:latest
    user: "10001:10001"
    group_add:
      - "{{ docker_gid }}"
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
        aliases:
          - neon-docker-manager
    ports:
      - 3000:3000
    environment:
      SDM_AUTH_USERNAME: neon
      SDM_AUTH_PASSWORD: "{{ users.simple_docker_manager.password }}"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - sdm-data:/data
{% endif %}
  skill_config:
    <<: *podman
    container_name: neon-skill-config
    image: ghcr.io/oscillatelabsllc/ovos-skill-config-tool:latest
    user: "0:0"
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
        aliases:
          - neon-skill-config
    ports:
      - 8010:8000
    volumes:
      - ${NEON_CONFIG_FOLDER}:/home/appuser/.config:rw
      - {{ neon_home }}/compose/neon-logo.png:/app/static/logo.png:ro
      - {{ neon_home }}/compose/skill-config.json:/app/static/config.json:ro
    environment:
      <<: *default-env-vars
      OVOS_CONFIG_USERNAME: neon
      OVOS_CONFIG_PASSWORD: "{{ users.neon_skill_config.password }}"
      OVOS_CONFIG_BASE_FOLDER: neon
      XDG_CONFIG_HOME: /home/appuser/.config
  users-service:
    <<: *podman
    depends_on:
      - rabbitmq
    container_name: neon-users-service
    image: ghcr.io/neongeckocom/neon-users-service:${MQ_IMAGE_TAG}
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
        aliases:
          - neon-users-service
    volumes:
      - xdg:/xdg:rw
      - {{ xdg_dir }}/share/neon/users-service:/data:rw
    environment:
      <<: *default-env-vars
  hana:
    <<: *podman
    depends_on:
      - rabbitmq
      - users-service
    container_name: neon-hana
    image: ghcr.io/neongeckocom/neon-hana:${HTTP_IMAGE_TAG}
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
    ports:
      - 8082:8080
    volumes:
      - xdg:/xdg:rw
    environment:
      <<: *default-env-vars
  tts_coqui:
    <<: *podman
    container_name: neon-tts-coqui
    image: ghcr.io/neongeckocom/neon-tts-plugin-coqui:${HTTP_IMAGE_TAG}
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
        aliases:
          - coqui
    ports:
      - 9666:9666
    volumes:
      - xdg:/xdg:rw
    environment:
      <<: *default-env-vars
  stt_fasterwhisper: # TODO: Neon image, with Neon user (permissions are a mess)
    <<: *podman
    container_name: neon-stt-fasterwhisper
    image: docker.io/smartgic/ovos-stt-server-fasterwhisper:alpha
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
        aliases:
          - fasterwhisper
    ports:
      - 8080:8080
    environment:
      <<: *default-env-vars
  iris:
    <<: *podman
    depends_on:
      - rabbitmq
    container_name: neon-iris
    user: root
    image: ghcr.io/neongeckocom/neon-iris:${HTTP_IMAGE_TAG}
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
        aliases:
          - iris
    ports:
      - 7860:7860
    volumes:
      - xdg:/xdg:rw
    environment:
      <<: *default-env-vars
      OVOS_CONFIG_FILENAME: diana.yaml
  iris_websat:
    <<: *podman
    depends_on:
      - rabbitmq
    container_name: neon-iris-websat
    image: ghcr.io/neongeckocom/neon-iris-websat:${HTTP_IMAGE_TAG}
    restart: unless-stopped
    logging: *default-logging
    hostname: $HOSTNAME
    networks:
      neon-core:
        aliases:
          - iris-websat
    ports:
      - 8001:8000
    volumes:
      - xdg:/xdg:rw
    environment:
      <<: *default-env-vars
      # OVOS_DEFAULT_CONFIG: /xdg/config/neon/diana.yaml
      OVOS_CONFIG_FILENAME: diana.yaml
  nginx:
    image: nginx:alpine
    container_name: neon-nginx
    logging: *default-logging
    restart: unless-stopped
    networks:
      neon-core:
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - {{ neon_home }}/compose/nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ neon_home }}/{{ common_name }}.crt:/etc/ssl/certs/{{ common_name }}.crt:ro
      - {{ neon_home }}/{{ common_name }}.key:/etc/ssl/private/{{ common_name }}.key:ro
  hub_config:
    <<: *podman
    logging: *default-logging
    restart: unless-stopped
    depends_on:
      - hana
    image: ghcr.io/neongeckocom/neon-hub-config:main
    environment:
      DIANA_PATH: /root/.config/neon/diana.yaml
      NEON_PATH: /root/.config/neon/neon.yaml
      HUB_ADMIN_TOKEN_FILE: /root/.config/neon/hub_admin.yaml
    container_name: neon-hub-config
    user: root
    networks:
      neon-core:
        aliases:
          - neon-hub-config
    ports:
      - 8005:80
    volumes:
      - ${NEON_CONFIG_FOLDER}:/root/.config
{% if ansible_os_family != 'Darwin' %}
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
{% endif %}
